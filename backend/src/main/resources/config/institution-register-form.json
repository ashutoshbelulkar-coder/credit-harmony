{
  "defaultGeography": "default",
  "geographies": {
    "default": {
      "label": "Default (dev seed)",
      "description": "Baseline register-member Step 1 layout for local development. Production would load the geography matching the tenant or operating region.",
      "sections": [
        {
          "id": "entity",
          "legend": "Entity Information",
          "layout": "grid2",
          "fields": [
            {
              "name": "legalName",
              "apiKey": "name",
              "label": "Legal Name",
              "inputType": "text",
              "required": true,
              "maxLength": 200,
              "placeholder": "Enter legal entity name"
            },
            {
              "name": "tradingName",
              "label": "Trading Name",
              "inputType": "text",
              "required": true,
              "maxLength": 200,
              "placeholder": "Enter trading name"
            },
            {
              "name": "registrationNumber",
              "label": "Registration Number",
              "inputType": "text",
              "required": false,
              "readOnly": true,
              "maxLength": 50,
              "description": "Assigned automatically when you submit.",
              "placeholder": "Assigned on submit"
            },
            {
              "name": "institutionType",
              "label": "Institution Type",
              "inputType": "select",
              "selectionMode": "single",
              "required": true,
              "optionSource": "institutionTypes",
              "placeholder": "Select type"
            }
          ]
        },
        {
          "id": "regulatory",
          "legend": "Regulatory Details",
          "layout": "grid2",
          "fields": [
            {
              "name": "jurisdiction",
              "label": "Jurisdiction",
              "inputType": "text",
              "required": true,
              "maxLength": 100,
              "placeholder": "e.g. Kenya"
            },
            {
              "name": "licenseNumber",
              "label": "License Number",
              "inputType": "text",
              "required": true,
              "maxLength": 50,
              "placeholder": "Enter license number"
            }
          ]
        },
        {
          "id": "contact",
          "legend": "Contact Information",
          "layout": "grid2",
          "fields": [
            {
              "name": "contactEmail",
              "label": "Contact Email",
              "inputType": "email",
              "required": true,
              "maxLength": 255,
              "placeholder": "compliance@institution.com"
            },
            {
              "name": "contactPhone",
              "label": "Contact Phone",
              "inputType": "tel",
              "required": true,
              "maxLength": 30,
              "placeholder": "+254 700 000 000"
            }
          ]
        },
        {
          "id": "participation",
          "legend": "Participation Type",
          "layout": "checkboxCards",
          "refineAtLeastOne": ["isDataSubmitter", "isSubscriber"],
          "fields": [
            {
              "name": "isDataSubmitter",
              "label": "Data Submission",
              "description": "Submit credit data to the bureau",
              "inputType": "checkbox",
              "required": false
            },
            {
              "name": "isSubscriber",
              "label": "Subscriber",
              "description": "Query credit reports from the bureau",
              "inputType": "checkbox",
              "required": false
            }
          ]
        },
        {
          "id": "consortium",
          "legend": "Consortium membership",
          "layout": "full",
          "visibleWhen": { "field": "isSubscriber", "equals": true },
          "fields": [
            {
              "name": "consortiumIds",
              "label": "Consortiums",
              "inputType": "multiselect",
              "selectionMode": "multiple",
              "required": false,
              "optionSource": "activeConsortiums",
              "placeholder": "Select consortiums…"
            }
          ]
        }
      ]
    },
    "kenya": {
      "label": "Kenya (sample geography)",
      "description": "Example geography-specific configuration: jurisdiction is a closed enum from config instead of free text.",
      "sections": [
        {
          "id": "entity",
          "legend": "Entity Information",
          "layout": "grid2",
          "fields": [
            {
              "name": "legalName",
              "apiKey": "name",
              "label": "Legal Name",
              "inputType": "text",
              "required": true,
              "maxLength": 200,
              "placeholder": "Enter legal entity name"
            },
            {
              "name": "tradingName",
              "label": "Trading Name",
              "inputType": "text",
              "required": true,
              "maxLength": 200,
              "placeholder": "Enter trading name"
            },
            {
              "name": "registrationNumber",
              "label": "Registration Number",
              "inputType": "text",
              "required": false,
              "readOnly": true,
              "maxLength": 50,
              "description": "Assigned automatically when you submit.",
              "placeholder": "Assigned on submit"
            },
            {
              "name": "institutionType",
              "label": "Institution Type",
              "inputType": "select",
              "selectionMode": "single",
              "required": true,
              "optionSource": "institutionTypes",
              "placeholder": "Select type"
            }
          ]
        },
        {
          "id": "regulatory",
          "legend": "Regulatory Details",
          "layout": "grid2",
          "fields": [
            {
              "name": "jurisdiction",
              "label": "Jurisdiction",
              "inputType": "select",
              "selectionMode": "single",
              "required": true,
              "placeholder": "Select jurisdiction",
              "options": [
                { "value": "Kenya", "label": "Kenya" },
                { "value": "Uganda", "label": "Uganda" },
                { "value": "Tanzania", "label": "Tanzania" }
              ]
            },
            {
              "name": "licenseNumber",
              "label": "License Number",
              "inputType": "text",
              "required": true,
              "maxLength": 50,
              "placeholder": "Enter license number"
            }
          ]
        },
        {
          "id": "contact",
          "legend": "Contact Information",
          "layout": "grid2",
          "fields": [
            {
              "name": "contactEmail",
              "label": "Contact Email",
              "inputType": "email",
              "required": true,
              "maxLength": 255,
              "placeholder": "compliance@institution.com"
            },
            {
              "name": "contactPhone",
              "label": "Contact Phone",
              "inputType": "tel",
              "required": true,
              "maxLength": 30,
              "placeholder": "+254 700 000 000"
            }
          ]
        },
        {
          "id": "participation",
          "legend": "Participation Type",
          "layout": "checkboxCards",
          "refineAtLeastOne": ["isDataSubmitter", "isSubscriber"],
          "fields": [
            {
              "name": "isDataSubmitter",
              "label": "Data Submission",
              "description": "Submit credit data to the bureau",
              "inputType": "checkbox",
              "required": false
            },
            {
              "name": "isSubscriber",
              "label": "Subscriber",
              "description": "Query credit reports from the bureau",
              "inputType": "checkbox",
              "required": false
            }
          ]
        },
        {
          "id": "consortium",
          "legend": "Consortium membership",
          "layout": "full",
          "visibleWhen": { "field": "isSubscriber", "equals": true },
          "fields": [
            {
              "name": "consortiumIds",
              "label": "Consortiums",
              "inputType": "multiselect",
              "selectionMode": "multiple",
              "required": false,
              "optionSource": "activeConsortiums",
              "placeholder": "Select consortiums…"
            }
          ]
        }
      ]
    }
  }
}
