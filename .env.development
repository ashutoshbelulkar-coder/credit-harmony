# Development environment — frontend only
# All /api requests are proxied to 127.0.0.1:8091 by default (see vite.config.ts → VITE_API_PROXY_TARGET)

# Base URL for API calls (proxied in dev, direct in prod)
VITE_API_BASE_URL=/api

# When true, API call failures fall back to static mock data
# Set to false to test against a live backend exclusively
VITE_USE_MOCK_FALLBACK=true

# Optional: artificial delay (ms) added to mock responses (useful for skeleton loader dev)
VITE_MOCK_DELAY_MS=0
