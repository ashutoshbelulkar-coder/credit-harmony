# HCB Admin Portal — local development (Spring Boot canonical API)
# Copy to .env.development and adjust as needed. Vite reads this when starting `npm run dev`.

# Spring API (default port 8090; SQLite DB under backend/data/ unless HCB_DB_PATH is set)
VITE_API_PROXY_TARGET=http://127.0.0.1:8090

# Use real API responses; do not fall back to JSON mocks when the server errors
VITE_USE_MOCK_FALLBACK=false

# Cloudflare Turnstile (optional). Leave empty to hide the widget; enable server check with HCB_CAPTCHA_ENABLED=true + HCB_TURNSTILE_SECRET_KEY.
# VITE_TURNSTILE_SITE_KEY=

# Register-member wizard: must match Spring GET/POST ?geography= and classpath config
# VITE_INSTITUTION_REGISTER_GEOGRAPHY=default
