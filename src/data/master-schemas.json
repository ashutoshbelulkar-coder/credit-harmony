{
  "masterSchemas": [
    {
      "id": "msm-1001",
      "name": "Telecom Master Schema",
      "sourceType": "telecom",
      "description": "Enterprise master schema for telecom alternate data ingestion.",
      "version": "v1.2",
      "status": "active",
      "fields": [
        { "name": "consumer_id", "dataType": "string", "required": true, "masking": "none", "description": "Unique consumer identifier." },
        { "name": "full_name", "dataType": "string", "required": true, "masking": "partial", "description": "Consumer full legal name." },
        { "name": "phone_number", "dataType": "string", "required": true, "masking": "partial", "description": "Primary mobile number." },
        { "name": "date_of_birth", "dataType": "date", "required": false, "masking": "full", "description": "Date of birth (if available)." },
        { "name": "avg_monthly_bill", "dataType": "decimal", "required": false, "masking": "none", "description": "Average monthly bill for last 3 months." },
        { "name": "payment_delay_days", "dataType": "integer", "required": false, "masking": "none", "description": "Days payment was delayed." }
      ],
      "createdBy": "Priya Sharma",
      "updatedBy": "Priya Sharma",
      "createdAt": "2026-01-12T10:15:00Z",
      "updatedAt": "2026-02-18T09:30:00Z",
      "rawJson": {
        "$schema": "https://json-schema.org/draft-07/schema",
        "title": "Telco Master Schema",
        "description": "Canonical information model for telecommunications service providers. Aligned with TM Forum SID and Open APIs.",
        "version": "1.0",
        "definitions": {
          "Party": {
            "type": "object",
            "description": "Any individual or organization that can play a role in a business interaction.",
            "properties": {
              "partyId": { "type": "string", "description": "Globally unique identifier for the party." },
              "partyType": { "type": "string", "enum": ["Individual", "Organization"] },
              "legalName": { "type": "string" },
              "displayName": { "type": "string" },
              "taxId": { "type": "string" },
              "status": { "type": "string", "enum": ["Active", "Inactive", "Suspended"] },
              "createdDate": { "type": "string", "format": "date" },
              "lastUpdated": { "type": "string", "format": "date" }
            },
            "required": ["partyId", "partyType", "legalName", "status"]
          },
          "PartyRole": {
            "type": "object",
            "description": "Associates a Party with a specific role type and validity period.",
            "properties": {
              "partyRoleId": { "type": "string" },
              "partyId": { "type": "string" },
              "roleType": { "type": "string", "enum": ["Customer", "EnterpriseCustomer", "Partner", "Vendor", "Regulator"] },
              "validFrom": { "type": "string", "format": "date" },
              "validTo": { "type": "string", "format": "date" },
              "status": { "type": "string", "enum": ["Active", "Inactive"] }
            },
            "required": ["partyRoleId", "partyId", "roleType", "validFrom", "status"]
          },
          "Customer": {
            "type": "object",
            "description": "A party role representing an entity receiving telecom services.",
            "properties": {
              "customerId": { "type": "string" },
              "partyRoleId": { "type": "string" },
              "customerType": { "type": "string", "enum": ["Residential", "SME", "Enterprise", "Government"] },
              "regCategory": { "type": "string" },
              "lifecycleState": { "type": "string", "enum": ["Prospect", "Active", "Suspended", "Churned"] },
              "customerSince": { "type": "string", "format": "date" }
            },
            "required": ["customerId", "partyRoleId", "customerType", "lifecycleState"]
          },
          "CustomerAccount": {
            "type": "object",
            "description": "The billing/financial account associated with one or more customers.",
            "properties": {
              "accountId": { "type": "string" },
              "accountNumber": { "type": "string" },
              "customerId": { "type": "string" },
              "accountStatus": { "type": "string", "enum": ["Active", "Closed", "Suspended"] },
              "billingCycle": { "type": "string", "enum": ["Monthly", "Quarterly", "Annual"] },
              "currency": { "type": "string" },
              "creditLimit": { "type": "number" },
              "billingAddressId": { "type": "string" }
            },
            "required": ["accountId", "accountNumber", "customerId", "accountStatus", "billingCycle", "currency"]
          },
          "ContactMedium": {
            "type": "object",
            "description": "A contact channel such as email, phone, or postal address.",
            "properties": {
              "contactMediumId": { "type": "string" },
              "partyId": { "type": "string" },
              "type": { "type": "string", "enum": ["Mobile", "Email", "Landline", "PostalAddress", "URL"] },
              "value": { "type": "string" },
              "countryCode": { "type": "string" },
              "language": { "type": "string" },
              "isPrimary": { "type": "boolean" },
              "isPreferredForNotification": { "type": "boolean" }
            },
            "required": ["contactMediumId", "partyId", "type", "value"]
          },
          "ProductSpecification": {
            "type": "object",
            "description": "Technical and commercial definition of a product independent of customer or price.",
            "properties": {
              "productSpecId": { "type": "string" },
              "name": { "type": "string" },
              "description": { "type": "string" },
              "category": { "type": "string", "enum": ["Mobile", "Broadband", "Enterprise", "IoT", "Voice", "Bundle"] },
              "subCategory": { "type": "string" },
              "version": { "type": "string" },
              "status": { "type": "string", "enum": ["Active", "Retired", "Draft"] }
            },
            "required": ["productSpecId", "name", "category", "status"]
          },
          "ProductOffering": {
            "type": "object",
            "description": "A marketable product offer combining one or more product specifications.",
            "properties": {
              "productOfferingId": { "type": "string" },
              "productSpecId": { "type": "string" },
              "name": { "type": "string" },
              "marketSegment": { "type": "string" },
              "channel": { "type": "array", "items": { "type": "string" } },
              "validFrom": { "type": "string", "format": "date" },
              "validTo": { "type": "string", "format": "date" },
              "isBundle": { "type": "boolean" }
            },
            "required": ["productOfferingId", "productSpecId", "name", "validFrom"]
          },
          "ProductPrice": {
            "type": "object",
            "description": "A charge or rate associated with a product offering.",
            "properties": {
              "productPriceId": { "type": "string" },
              "productOfferingId": { "type": "string" },
              "priceName": { "type": "string" },
              "priceType": { "type": "string", "enum": ["OneTime", "Recurring", "UsageBased"] },
              "chargeBasis": { "type": "string" },
              "amount": { "type": "number" },
              "currency": { "type": "string" },
              "taxCategory": { "type": "string" }
            },
            "required": ["productPriceId", "productOfferingId", "priceType", "amount", "currency"]
          },
          "Service": {
            "type": "object",
            "description": "An instantiated service being delivered to a customer.",
            "properties": {
              "serviceId": { "type": "string" },
              "serviceSpecId": { "type": "string" },
              "customerAccountId": { "type": "string" },
              "circuitOrMSISDN": { "type": "string" },
              "serviceStatus": { "type": "string", "enum": ["Active", "Pending", "Suspended", "Disconnected", "Cancelled"] },
              "activationDate": { "type": "string", "format": "date" },
              "terminationDate": { "type": ["string", "null"], "format": "date" },
              "locationId": { "type": "string" }
            },
            "required": ["serviceId", "serviceSpecId", "customerAccountId", "serviceStatus", "activationDate"]
          },
          "Location": {
            "type": "object",
            "description": "A physical or logical location such as a customer premise or network site.",
            "properties": {
              "locationId": { "type": "string" },
              "type": { "type": "string", "enum": ["CustomerPremise", "NetworkSite", "DataCenter", "Tower", "Manhole"] },
              "addressLine1": { "type": "string" },
              "city": { "type": "string" },
              "state": { "type": "string" },
              "pinCode": { "type": "string" },
              "country": { "type": "string" },
              "latitude": { "type": "number" },
              "longitude": { "type": "number" }
            },
            "required": ["locationId", "type", "city", "country"]
          },
          "Resource": {
            "type": "object",
            "description": "A physical or logical resource used to deliver telecom services.",
            "properties": {
              "resourceId": { "type": "string" },
              "resourceSpecId": { "type": "string" },
              "serialNumber": { "type": "string" },
              "status": { "type": "string", "enum": ["InService", "OutOfService", "Planned", "Retired"] },
              "installDate": { "type": "string", "format": "date" },
              "locationId": { "type": "string" },
              "linkedServiceId": { "type": "string" },
              "owner": { "type": "string", "enum": ["Operator", "CustomerLeased", "CustomerOwned"] }
            },
            "required": ["resourceId", "resourceSpecId", "status"]
          },
          "UsageEvent": {
            "type": "object",
            "description": "A single CDR, IPDR, or session-level usage record.",
            "properties": {
              "usageEventId": { "type": "string" },
              "serviceId": { "type": "string" },
              "eventType": { "type": "string", "enum": ["VoiceCall", "SMS", "DataSession", "MMS", "RoamingCall"] },
              "startTime": { "type": "string", "format": "date-time" },
              "endTime": { "type": "string", "format": "date-time" },
              "volume": { "type": "number" },
              "volumeUnit": { "type": "string", "enum": ["seconds", "bytes", "messages"] },
              "direction": { "type": "string", "enum": ["Originating", "Terminating"] },
              "originatingId": { "type": "string" },
              "destinationId": {},
              "networkType": { "type": "string" }
            },
            "required": ["usageEventId", "serviceId", "eventType", "startTime", "volume", "volumeUnit"]
          },
          "Bill": {
            "type": "object",
            "description": "A rendered invoice for a billing account covering a billing period.",
            "properties": {
              "billId": { "type": "string" },
              "billingAccountId": { "type": "string" },
              "billNumber": { "type": "string" },
              "billPeriodStart": { "type": "string", "format": "date" },
              "billPeriodEnd": { "type": "string", "format": "date" },
              "billDate": { "type": "string", "format": "date" },
              "dueDate": { "type": "string", "format": "date" },
              "totalAmount": { "type": "number" },
              "taxAmount": { "type": "number" },
              "currency": { "type": "string" },
              "status": { "type": "string", "enum": ["Draft", "Issued", "Paid", "Overdue", "Disputed"] }
            },
            "required": ["billId", "billingAccountId", "billNumber", "billPeriodStart", "billPeriodEnd", "totalAmount", "currency", "status"]
          },
          "Payment": {
            "type": "object",
            "description": "A payment received from a customer.",
            "properties": {
              "paymentId": { "type": "string" },
              "billingAccountId": { "type": "string" },
              "paymentMethod": { "type": "string", "enum": ["Cash", "Card", "UPI", "DirectDebit", "BankTransfer", "DigitalWallet"] },
              "amount": { "type": "number" },
              "currency": { "type": "string" },
              "paymentDate": { "type": "string", "format": "date" },
              "referenceNo": { "type": "string" },
              "status": { "type": "string", "enum": ["Pending", "Settled", "Failed", "Refunded"] }
            },
            "required": ["paymentId", "billingAccountId", "paymentMethod", "amount", "currency", "paymentDate", "status"]
          },
          "Agreement": {
            "type": "object",
            "description": "A legal or commercial agreement between parties.",
            "properties": {
              "agreementId": { "type": "string" },
              "agreementType": { "type": "string", "enum": ["ServiceContract", "EnterpriseContract", "DataSharingConsent", "PartnerAgreement"] },
              "customerId": { "type": "string" },
              "productOfferingId": { "type": "string" },
              "status": { "type": "string", "enum": ["Active", "Expired", "Terminated", "Pending"] },
              "effectiveStart": { "type": "string", "format": "date" },
              "effectiveEnd": { "type": "string", "format": "date" },
              "jurisdiction": { "type": "string" },
              "signedDate": { "type": "string", "format": "date" }
            },
            "required": ["agreementId", "agreementType", "customerId", "status", "effectiveStart"]
          }
        },
